# Resend — get your API key at https://resend.com/api-keys
RESEND_API_KEY=re_your_key_here

# The "From" address. For local dev / before domain verification, use:
#   onboarding@resend.dev
# In production, use an address on a verified domain, e.g.:
#   hello@upwardphysio.com
FROM_EMAIL=onboarding@resend.dev

# Where contact form submissions get delivered
TO_EMAIL=info@upwardphysio.com
